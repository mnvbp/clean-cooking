datatally <- data %>% group_by(v1, v2, v3) %>% tally()
newdata <- function(data, v1=data$wealth,v2=data$dhsclust, v3=data$close_dist) {
datatally <- data %>% group_by(v1, v2, v3) %>% tally()
sums <- aggregate(n ~ v2, data=datatally, sum)
sums <- rename(sums, "sum" = n)
datatally <- merge(datatally, sums)
datatally$proportion <- datatally$n / datatally$sum
ggplot(datatally, aes(v3, proportion, color = v1)) + geom_point() + facet_wrap(~v1) + geom_smooth(method='lm')
}
